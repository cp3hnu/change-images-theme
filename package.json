{
  "name": "change-images-theme",
  "version": "1.0.0",
  "description": "A Node.js CLI that applies a visual theme to PNG/JPG assets: match brand hues in HSL, recolor with CSS hue-rotate, and preserve alpha (rebrand / white-label friendly).",
  "author": "Wei Zhao <cp3hnu@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/cp3hnu/change-images-theme#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cp3hnu/change-images-theme.git"
  },
  "bugs": {
    "url": "https://github.com/cp3hnu/change-images-theme/issues"
  },
  "type": "module",
  "bin": {
    "cit": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "image",
    "theme",
    "theming",
    "rebrand",
    "color",
    "recolor",
    "cli",
    "sharp",
    "png",
    "jpg"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}