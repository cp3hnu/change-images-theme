{
  "name": "change-image-theme",
  "version": "0.1.0",
  "description": "A Node.js CLI that applies a visual theme to PNG/JPG assets: shift brand hues from a hex color map while preserving saturation/lightness and alpha (rebrand / white-label friendly).",
  "type": "module",
  "bin": {
    "cit": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "image",
    "theme",
    "theming",
    "rebrand",
    "color",
    "recolor",
    "cli",
    "sharp",
    "png",
    "jpg"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}